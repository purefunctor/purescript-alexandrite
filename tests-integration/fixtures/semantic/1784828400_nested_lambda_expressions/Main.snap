data Maybe :: Type -> Type
data Maybe @a
  | Nothing :: Maybe a
  | Just :: a -> Maybe a

nested :: forall t t1. t -> t1 -> t
nested = \first -> \second -> first

caseBody :: Maybe Int -> Int
caseBody =
  \maybe ->
    case maybe of
      Nothing -> 0
      (Just value) -> value
