apply :: forall a b. (a -> b) -> a -> b
apply = \function -> \value -> function value

argument :: forall t. t -> t
argument = apply @t @t \value -> value

functionPosition :: forall t t1. (t -> t1) -> t -> t1
functionPosition = (\function -> function) (apply @t @t1)
