data Choice :: Type -> Type
data Choice @a
  | Empty :: Choice a
  | One :: a -> Choice a
  | Pair :: a -> a -> Choice a

guarded :: Boolean -> Choice (Choice Int) -> Int
guarded = \condition -> \choice ->
  case choice of
    (One nested)
      | condition, (One value) <- nested -> value
    (Pair left right)
      | (One value) <- left -> value
      | (One value) <- right -> value
    _ -> 0

withWhere :: Choice Int -> Int
withWhere = \choice ->
  case choice of
    (One value) -> local
      where
      local :: Int
      local = value
    _ -> 0
