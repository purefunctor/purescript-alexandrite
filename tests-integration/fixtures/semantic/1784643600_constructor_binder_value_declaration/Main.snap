data Maybe :: Type -> Type
data Maybe @a
  | Just :: a -> Maybe a
  | Nothing :: Maybe a

fromMaybe :: forall t. t -> Maybe t -> t
fromMaybe = \default -> \(Just value) -> value
fromMaybe = \default -> \Nothing -> default
