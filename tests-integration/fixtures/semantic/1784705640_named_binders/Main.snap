data Maybe :: Type -> Type
data Maybe @a
  | Just :: a -> Maybe a
  | Nothing :: Maybe a

fromMaybe :: forall a. a -> Maybe a -> a
fromMaybe = \fallback -> \whole@(Just value) -> value
fromMaybe = \fallback -> \Nothing -> fallback
