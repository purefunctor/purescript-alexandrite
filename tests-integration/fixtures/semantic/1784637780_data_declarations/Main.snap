data Proxy :: forall (k :: Type). k -> Type
data Proxy @a
  | Proxy :: Proxy a

newtype Tagged :: forall (k :: Type). k -> Type -> Type
newtype Tagged @t @a
  | Tagged :: a -> Tagged t a

data Maybe :: Type -> Type
data Maybe @a
  | Just :: a -> Maybe a
  | Nothing :: Maybe a
